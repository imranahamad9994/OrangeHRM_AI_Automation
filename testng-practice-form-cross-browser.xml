<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Automation Practice Form Cross Browser Suite" parallel="false">
    <listeners>
        <listener class-name="com.imran.automation.listeners.TestListener"/>
    </listeners>

    <test name="Chrome Practice Form Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.imran.automation.tests.practice.AutomationPracticeFormTest"/>
        </classes>
    </test>

    <test name="Firefox Practice Form Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.imran.automation.tests.practice.AutomationPracticeFormTest"/>
        </classes>
    </test>

    <test name="Edge Practice Form Tests">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.imran.automation.tests.practice.AutomationPracticeFormTest"/>
        </classes>
    </test>
</suite>
